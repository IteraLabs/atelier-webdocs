# Keep the build context lean. Anything not copied into the image
# stays in this list.

# .git/ is deliberately NOT ignored: the in-image `mkdocs build --strict`
# needs it for git-revision-date-localized, which warns (and therefore
# fails the strict build) without a git directory.
.github/
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
.DS_Store

# Build outputs that should be regenerated inside the image.
site/

# Editor / OS noise.
.vscode/
.idea/

# Local-only files.
*.env
*.local

# Doc-source-only files we don't need at runtime.
CONTRIBUTING.md
.gitignore
.dockerignore
.editorconfig
